{
    "name": "stash",
    "version": "0.0.1",
    "scripts": {
        "dev": "source ../.env && vite dev",
        "build": "svelte-kit sync && vite build",
        "start": "vite",
        "check": "svelte-check --tsconfig ./jsconfig.json",
        "check:watch": "svelte-check --tsconfig ./jsconfig.json --watch",
        "format": "pnpm run format:prettier && pnpm run format:stylelint",
        "format:prettier": "npx prettier . --write",
        "format:stylelint": "npx stylelint --fix **/*.{css,scss,svelte}"
    },
    "devDependencies": {
        "@egjs/grid": "^1.18.0",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@mdi/js": "^7.4.47",
        "@prisma/adapter-pg": "^7.4.2",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@types/fuzzy-search": "^2.1.5",
        "@types/mime-types": "^3.0.1",
        "@types/turndown": "^5.0.6",
        "eslint-plugin-svelte": "3.15.0",
        "hash-wasm": "^4.12.0",
        "js-pick-file": "^1.0.13",
        "node-html-parser": "^7.0.2",
        "postcss": "^8.5.10",
        "postcss-html": "^1.8.1",
        "prettier-plugin-svelte": "^3.5.0",
        "pretty-bytes": "^7.1.0",
        "prisma": "^7.4.2",
        "sass": "^1.97.3",
        "stylelint": "^17.4.0",
        "stylelint-config-clean-order": "^8.0.1",
        "stylelint-config-recommended-scss": "^17.0.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-scss": "^7.0.0",
        "svelte": "5.53.6",
        "svelte-check": "^4.4.4",
        "svelte-loading-spinners": "^0.3.6",
        "svelte-preprocess": "^6.0.3",
        "ts-exif-parser": "^0.2.2",
        "typescript": "^5.9.3"
    },
    "type": "module",
    "dependencies": {
        "@openrouter/ai-sdk-provider": "^2.9.0",
        "@prisma/client": "^7.4.2",
        "ai": "^6.0.174",
        "cookie": "^1.1.1",
        "fuse.js": "^7.1.0",
        "fuzzy-search": "^3.2.1",
        "mdi-svelte": "^1.1.2",
        "mime-types": "3.0.2",
        "redis": "^5.11.0",
        "runed": "^0.37.1",
        "select-files": "^1.0.1",
        "svelte-dropzone": "^1.0.6",
        "svelte-local-storage-store": "^0.6.4",
        "svelte-markdown": "^0.4.1",
        "turndown": "^7.2.2",
        "vite": "^7.3.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@parcel/watcher",
            "@prisma/client",
            "@prisma/engines",
            "esbuild",
            "prisma",
            "svelte-preprocess"
        ]
    }
}
