# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Connection string for Prisma ORM (used by the 'app' and 'worker' services).
# By default, this connects to the 'db' container defined in docker-compose.yml.
DATABASE_URL="postgresql://postgres:postgres@db:5432/postgres"


# -----------------------------------------------------------------------------
# Gatekeeper Configuration
# -----------------------------------------------------------------------------
# The target URL that the gatekeeper proxy should point to (typically the frontend app).
PROXY_TARGET_URL="http://app:3000"


# -----------------------------------------------------------------------------
# AI Configuration (Optional)
# -----------------------------------------------------------------------------
# Required if you want to use AI tagging or AI renaming features.
OPENROUTER_API_KEY="sk-or-v1-..."

# The model to use for visual AI tagging via OpenRouter.
# Recommended: a strong multimodal model like gemini-pro-vision, claude-3-haiku, etc.
VISUAL_AI_MODEL="google/gemini-pro-vision"

# The model to use for AI renaming tasks via OpenRouter.
# Recommended: a fast and cheap text model.
RENAME_AI_MODEL="google/gemini-pro"
