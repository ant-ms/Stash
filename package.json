{
  "name": "stash",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "test:infra:up": "docker-compose -f tests/docker-compose.yml up -d && sleep 5",
    "test:infra:down": "docker-compose -f tests/docker-compose.yml down",
    "test:schema:create": "psql \"$TEST_DB_URL\" -c \"CREATE DATABASE \\\"$TEST_SCHEMA\\\";\" && psql \"${TEST_DB_URL%/*}/$TEST_SCHEMA\" -v ON_ERROR_STOP=1 -f prisma/migrations/0_init/migration.sql",
    "test:schema:drop": "psql \"$TEST_DB_URL\" -c \"DROP DATABASE IF EXISTS \\\"$TEST_SCHEMA\\\" WITH (FORCE);\"",
    "test:seed": "DATABASE_URL=\"$TEST_DATABASE_URL\" MEDIA_ROOT=\"$(pwd)/_frontend/media\" THUMB_ROOT=\"$(pwd)/_frontend/thumbnails\" bun run tests/seed.ts",
    "test:run": "cd tests && npx playwright test --config playwright.config.ts",
    "test:update-snapshots": "cd tests && npx playwright test --config playwright.config.ts --update-snapshots",
    "test:all": "bash tests/run.sh",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "hash-wasm": "^4.12.0",
    "mime-types": "3.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/mime-types": "^3.0.1",
    "prisma": "^7.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma"
    ]
  }
}
